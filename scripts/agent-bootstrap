#!/usr/bin/env sh
set -eu

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT"

hr() {
  printf '\n== %s ==\n' "$1"
}

exists() {
  if [ -e "$1" ]; then
    printf 'ok      %s\n' "$1"
  else
    printf 'missing %s\n' "$1"
  fi
}

first_match() {
  file="$1"
  pattern="$2"
  if [ -f "$file" ]; then
    grep -E "$pattern" "$file" | head -n 1 || true
  fi
}

print_between() {
  file="$1"
  start="$2"
  end="$3"
  if [ -f "$file" ]; then
    awk "/$start/{flag=1} flag{print} /$end/{if(flag){exit}}" "$file"
  fi
}

hr "Project"
printf 'name: msc-ux-audit\n'
printf 'root: %s\n' "$ROOT"
printf 'time: %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

hr "Git Snapshot"
git status --short --branch
printf '\nlatest commit:\n'
git log -1 --oneline 2>/dev/null || true

hr "Required Read Order"
cat <<'EOF'
1. AGENTS.md
2. AI_CONTEXT.md
3. TODO.md
4. latest version block in changelog.html
5. docs/style-guide.md if changing page structure or visuals
6. docs/ai-workflow.md if changing handoff/version rules
7. docs/architecture-understanding.md if validating architecture assumptions
8. docs/project-memory-layer-localization.md if changing repo memory workflow
EOF

hr "Memory Files"
exists "AGENTS.md"
exists "AI_CONTEXT.md"
exists "TODO.md"
exists "changelog.html"
exists "docs/ai-workflow.md"
exists "docs/architecture-understanding.md"
exists "docs/ai-dialogue.md"
exists "docs/project-memory-layer-reference.md"
exists "docs/project-memory-layer-localization.md"

hr "Current Baseline"
print_between "AI_CONTEXT.md" "^## Current Baseline" "^## Read Order" | sed '$d' || true

hr "Current Focus"
print_between "TODO.md" "^## .*当前焦点" "^## .*主线任务" | sed '$d' || true

hr "Blocked / Waiting"
print_between "TODO.md" "^## .*阻塞中" "^## .*短期" | sed '$d' || true

hr "Latest Visible Version"
latest_version="$(first_match "changelog.html" 'v[0-9]+\.[0-9]+\.[0-9]+' | sed -E 's/.*(v[0-9]+\.[0-9]+\.[0-9]+).*/\1/' || true)"
if [ -n "${latest_version:-}" ]; then
  printf '%s\n' "$latest_version"
else
  printf 'No vX.Y.Z version string found in changelog.html\n'
fi

hr "Architecture Entry Points"
cat <<'EOF'
index.html                 home / site map
chatA.html ... chatK.html  product, UX, strategy, and UI modules
decisions.html             aggregated feedback decision dashboard
fb.js                      shared feedback rendering and local merge
sb.js                      browser feedback client for /api/feedback
server.js                  Express runtime, feedback API, static-file boundary
nav.js                     shared navigation injection
EOF

hr "High-Risk Areas"
cat <<'EOF'
feedback sync: fb.js, sb.js, server.js, decisions.html
static exposure: server.js
shared navigation: nav.js, index.html
feedback IDs / versions: .fb[data-id], data-ver, data-desc
strategy rewrite: chatJ.html, chatK.html, TODO.md
handoff state: AI_CONTEXT.md, TODO.md, changelog.html
EOF

hr "Sidecar Experiments"
if [ -d "ai-bridge/threads" ]; then
  printf 'ai-bridge threads:\n'
  find ai-bridge/threads -maxdepth 1 -type f -name '*.md' | sort | sed 's/^/- /'
else
  printf 'ai-bridge: not present\n'
fi
if [ -d "telegram-agent-bridge" ]; then
  printf 'telegram-agent-bridge: present, sidecar experiment only\n'
else
  printf 'telegram-agent-bridge: not present\n'
fi

hr "Local Commands"
cat <<'EOF'
npm start
node --check server.js
node --check sb.js
node --check fb.js
node --check nav.js
git diff --check
EOF

hr "Agent Startup Instruction"
cat <<'EOF'
Before editing, read the required files above and then explain:
- what this project is
- current goal and blockers
- relevant architecture layers
- files you expect to touch
- risks you will avoid
EOF
